{
    "Resources": {
        "MyQueue": {
            "Type": "AWS::SQS::Queue"
        },
        "MyQueuePolicy": {
            "Type": "AWS::SQS::QueuePolicy",
            "Properties": {
                "PolicyDocument": {
                    "Version": "2012-10-17",
                    "Statement":[{
                        "Action": ["sqs:SendMessage", "sqs:ReceiveMessages"],
                        "Effect": "Allow",
                        "Resource": { "Fn::GetAtt": ["MyQueue", "Arn"] },
                        "Principal": {
                            "AWS": {
                                "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:root"
                            }
                        }
                    }]
                },
                "Queues": [
                    { "Ref": "MyQueue" }
                ]
            }
        }
    }
}
